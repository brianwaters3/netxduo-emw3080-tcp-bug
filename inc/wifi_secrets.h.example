/* Copy this file to wifi_secrets.h and fill in your real WiFi credentials.
 * wifi_secrets.h is gitignored.
 *
 * mx_wifi_conf.h includes this file (if present) before its placeholder
 * defines, so these values override the YOUR_SSID/YOUR_PASSWORD that ship
 * with the ST sample.
 */
#ifndef WIFI_SECRETS_H
#define WIFI_SECRETS_H

#define WIFI_SSID       "your-ssid-here"
#define WIFI_PASSWORD   "your-password-here"

#endif /* WIFI_SECRETS_H */
